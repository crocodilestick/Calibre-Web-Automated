msgstr "已標記為未讀"

#: cps/templates/detail.html:545 cps/templates/detail.html:546 cps/templates/detail.html:851 cps/templates/listenmp3.html:166
msgid "Restore from archive"
msgstr "從歸檔中還原"

#: cps/templates/detail.html:545 cps/templates/detail.html:546 cps/templates/detail.html:852 cps/templates/listenmp3.html:166
